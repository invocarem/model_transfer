# Worker (spark2) — copy this file to .env on spark2 only.
# CLI flags override these values.
#
# RANK=1 receives files. MASTER_ADDR must match the head (spark1) IP.
# SRC must list the same files as on the master (shared storage).
# DEST is where the model is written on this machine.

MODEL_TRANSFER_MODE=rdma
MODEL_TRANSFER_RANK=1
MODEL_TRANSFER_WORLD_SIZE=2
MODEL_TRANSFER_MASTER_ADDR=192.168.100.11
MODEL_TRANSFER_MASTER_PORT=29500

# Must match the master (gloo or nccl on both).
MODEL_TRANSFER_TORCH_BACKEND=gloo

MODEL_TRANSFER_SRC=
MODEL_TRANSFER_DEST=
