# Head / master (spark1) — copy this file to .env on spark1 only.
# CLI flags override these values.
#
# RANK=0 sends files. MASTER_ADDR is usually this machine’s IP (spark1).
# DEST must not equal SRC on this host or the run may skip all files.

MODEL_TRANSFER_MODE=rdma
MODEL_TRANSFER_RANK=0
MODEL_TRANSFER_WORLD_SIZE=2
MODEL_TRANSFER_MASTER_ADDR=192.168.100.11
MODEL_TRANSFER_MASTER_PORT=29500

MODEL_TRANSFER_SRC=
MODEL_TRANSFER_DEST=
